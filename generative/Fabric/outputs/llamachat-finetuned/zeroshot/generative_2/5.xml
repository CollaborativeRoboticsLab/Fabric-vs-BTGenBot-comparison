<Plan> 
                <Sequence name="moveRobot">
                    <PipelineSequence name="moveToPredefinedPos">
                        <RateController hz="3">
                            <Sequence>
                                <ComputePathToPose goal="2;-0.5;0;0" path="map" planner_id="GridBased" />
                            </Sequence>
                        </RateController>
                        <FollowPath path="{path}" controller_id="FollowPath" />
                    </PipelineSequence>
                    <ParallelNode>
                        <Sequence name="moveToPredefinedOrient">
                            <ComputePathToPose goal="0;2.0;0;0" path="map" planner_id="FollowPath" />
                        </Sequence>
                        <Sequence name="moveToPredefinedOrient">
                            <ComputePathToPose goal="0;-2.0;0;0" path="map" planner_id="FollowPath" />
                        </Sequence>
                        <Sequence name="moveToPredefinedOrient">
                            <ComputePathToPose goal="0;0;-2.0;0" path="map" planner_id="FollowPath" />
                        </Sequence>
                    </ParallelNode>
                </Sequence>
            </Plan>