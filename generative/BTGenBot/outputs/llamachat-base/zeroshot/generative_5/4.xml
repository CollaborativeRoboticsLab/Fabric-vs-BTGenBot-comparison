<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in order -->
            <Fallback>
                <Sequence>
                    <GetTarget target="StationA" />
                    <MoveTo target="{target}" />
                </Sequence>
                <Sequence>
                    <GetTarget target="StationE" />
                    <MoveTo target="{target}" />
                </Sequence>
                <Sequence>
                    <GetTarget target="StationF" />
                    <MoveTo target="{target}" />
                </Sequence>
                <Sequence>
                    <GetTarget target="StationD" />
                    <MoveTo target="{target}" />
                </Sequence>
            </Fallback>
            <Sequence>
                <GetTarget target="StationB" />
                <MoveTo target="{target}" />
            </Sequence>
        </Sequence>
    </BehaviorTree>
</root>