<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in order -->
            <Fallback>
                <Sequence>
                    <GetField input_name="stationA" output_value="{stationA}" />
                    <MoveTo goal="{stationA}" />
                </Sequence>
                <ForceFailure>
                    <GetField input_name="stationA" output_value="{stationA}" />
                    <GetField input_name="stationE" output_value="{stationE}" />
                    <MoveTo goal="{stationE}" />
                </ForceFailure>
                <ForceFailure>
                    <GetField input_name="stationA" output_value="{stationA}" />
                    <GetField input_name="stationE" output_value="{stationE}" />
                    <GetField input_name="stationF" output_value="{stationF}" />
                    <MoveTo goal="{stationF}" />
                </ForceFailure>
                <ForceFailure>
                    <GetField input_name="stationA" output_value="{stationA}" />
                    <GetField input_name="stationE" output_value="{stationE}" />
                    <GetField input_name="stationF" output_value="{stationF}" />
                    <GetField input_name="stationD" output_value="{stationD}" />
                    <MoveTo goal="{stationD}" />
                </ForceFailure>
            </Fallback>
        </Sequence>
    </BehaviorTree>
</root>