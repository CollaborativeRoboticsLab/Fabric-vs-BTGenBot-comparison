<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationC, StationD in order -->
            <Sequence>
                <SubTree ID="StationA" />
                <SubTree ID="StationE" condition="CanMove" />
                <SubTree ID="StationC" />
                <SubTree ID="StationD" />
            </Sequence>
            <!-- If StationE cannot be reached -->
            <SubTree ID="StationB" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationA">
        <Sequence>
            <Action ID="MoveTo" goal="StationA" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationB">
        <Sequence>
            <Action ID="MoveTo" goal="StationB" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationC">
        <Sequence>
            <Action ID="MoveTo" goal="StationC" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationD">
        <Sequence>
            <Action ID="MoveTo" goal="StationD" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationE">
        <Sequence>
            <Fallback>
                <Sequence>
                    <Action ID="MoveTo" goal="StationE" />
                </Sequence>
                <Sequence>
                    <Action ID="MoveTo" goal="StationB" />
                </Sequence>
            </Fallback>
        </Sequence>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="MoveTo">
            <input_port name="goal">Target location for moving</input_port>
        </Action>
    </TreeNodesModel>
</root>