<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA to StationE to StationF to StationD -->
            <SubTree ID="StationEAction" target="StationE" />
            <SubTree ID="StationFAction" target="StationF" />
            <SubTree ID="StationDAction" target="StationD" />
            
            <!-- if StationE cannot be reached -->
            <Fallback ID="StationEAction">
                <Switch2 case_1="true" case_2="false" label="Can move to StationE" value="canMoveToStationE">
                    <Action ID="MoveTo" label="Move to" target="StationB" name="StationEAction" />
                </Switch2>
            </Fallback>
            
            <!-- if StationF cannot be reached -->
            <Fallback ID="StationFAction">
                <Switch2 case_1="true" case_2="false" label="Can move to StationF" value="canMoveToStationF">
                    <Action ID="MoveTo" label="Move to" target="StationC" name="StationFAction" />
                </Switch2>
            </Fallback>
            
            <Action ID="AlwaysRunning" name="KeepRunning">
                <Inverter>
                     <ValueTrigger trigger="0" >
                        <Condition ID="IsRobotAtStation" name="RobotAtStation" />
                     </ValueTrigger>
                </Inverter>
            </Action>
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationEAction">
        <Sequence>
            <Action ID="MoveTo" target="StationE" name="MoveToStationE" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationFAction">
        <Sequence>
            <Action ID="MoveTo" target="StationF" name="MoveToStationF" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationDAction">
        <Sequence>
            <Action ID="MoveTo" target="StationD" name="MoveToStationD" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="AlwaysRunning">
        <Action name="KeepRunning">
            <Inverter>
                 <ValueTrigger trigger="0" >
                    <Condition ID="IsRobotAtStation" name="RobotAtStation" />
                 </ValueTrigger>
             </Inverter>
        </Action>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="AlwaysRunning"/>
        <Action ID="MoveTo">
            <input_port name="label"/>
            <input_port name="target"/>
        </Action>
        <Condition ID="IsRobotAtStation"/>
    </TreeNodesModel>
</root>