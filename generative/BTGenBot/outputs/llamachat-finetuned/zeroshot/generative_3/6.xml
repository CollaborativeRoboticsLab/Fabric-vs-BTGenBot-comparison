<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
           ; Visit Stations A, E, C, D in order. If StationE is not reachable,
           ; go to StationB.
            <Sequence>
                <SubTree ID="StationA" />
                <SubTree ID="StationE" />
                <SubTree ID="StationC" />
                <SubTree ID="StationD" />
                <ForceFailure>
                    <SubTree ID="StationE" />
                </ForceFailure>
                <SubTree ID="StationB" />
            </Sequence>
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationA">
        <Sequence>
            <MoveTo goal="0.579;0.000" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationB">
        <Sequence>
            <MoveTo goal="0.700;0.000" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationC">
        <Sequence>
            <MoveTo goal="0.000;0.700" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationD">
        <Sequence>
            <MoveTo goal="-0.800;0.000" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationE">
        <Sequence>
            <MoveTo goal="-0.350;0.350" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="SubTree">
        <Action ID="MoveTo" name="Move To" />
    </BehaviorTree>
</root>