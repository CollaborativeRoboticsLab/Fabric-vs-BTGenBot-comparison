<root main_tree_to_execute = "MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <Fallback>
                <Sequence>
                    <MoveTo location="StationA"/>
                </Sequence>
                <Sequence>
                    <MoveTo location="StationE"/>
                </Sequence>
                <Sequence>
                    <MoveTo location="StationF"/>
                </Sequence>
                <Sequence>
                    <MoveTo location="StationD"/>
                </Sequence>
                <SetBlackboard output_key="station_not_reached" value="0" />
                <SetBlackboard output_key="station_visited_sequence" value="StationA,StationE,StationF,StationD,StationB" />
                <Fallback>
                    <Sequence>
                        <MoveTo location="StationB"/>
                    </Sequence>
                    <Sequence>
                        <MoveTo location="StationD"/>
                    </Sequence>
                </Fallback>
            </Fallback>
        </Sequence>
    </BehaviorTree>
</root>