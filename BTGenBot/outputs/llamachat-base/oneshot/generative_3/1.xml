<root main_tree_to_execute = "MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <MoveTo location="StationA"/>
            <MoveTo location="StationE"/>
            <MoveTo location="StationC"/>
            <MoveTo location="StationD"/>
            <IFThenElse>
                <Fallback>
                    <Sequence>
                        <MoveTo location="StationB"/>
                    </Sequence>
                </Fallback>
                <Sequence>
                    <MoveTo location="StationA"/>
                    <MoveTo location="StationE"/>
                </Sequence>
            </IFThenElse>
        </Sequence>
    </BehaviorTree>
</root>