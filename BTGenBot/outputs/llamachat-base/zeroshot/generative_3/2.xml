<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationC, StationD in sequence -->
            <Sequence>
                <SubTree ID="VisitStations" />
            </Sequence>
            <SubTree ID="VisitStations" station_id="StationA" />
            <SubTree ID="VisitStations" station_id="StationE" />
            <SubTree ID="VisitStations" station_id="StationC" />
            <SubTree ID="VisitStations" station_id="StationD" />
            <!-- If StationE cannot be reached, move to StationB -->
            <SubTree ID="MoveToStation" station_id="StationE" fail_to_station_action="MoveToStation" station_id="StationB" />
        </Sequence>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="MoveToStation">
            <input_port name="station_id"/>
        </Action>
        <Action ID="MoveTo">
            <input_port name="goal"/>
        </Action>
    </TreeNodesModel>
</root>