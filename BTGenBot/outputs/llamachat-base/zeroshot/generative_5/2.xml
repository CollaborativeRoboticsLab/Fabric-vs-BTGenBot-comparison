<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <Fallback>
                <SubTree ID="StationA" />
                <SubTree ID="StationB" />
            </Fallback>
            <SubTree ID="StationE" />
            <SubTree ID="StationF" />
            <SubTree ID="StationD" />
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationA">
        <Sequence>
            <Action ID="MoveTo" goal="StationA" />
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationB">
        <Sequence>
            <Action ID="MoveTo" goal="StationB" />
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationC">
        <Sequence>
            <Action ID="MoveTo" goal="StationC" />
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationD">
        <Sequence>
            <Action ID="MoveTo" goal="StationD" />
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationE">
        <Sequence>
            <Fallback>
                <Action ID="MoveTo" goal="StationE" />
                <Action ID="MoveTo" goal="StationC" />
            </Fallback>
        </Sequence>
    </BehaviorTree>
    <BehaviorTree ID="StationF">
        <Sequence>
            <Action ID="MoveTo" goal="StationF" />
        </Sequence>
    </BehaviorTree>
    <TreeNodesModel>
        <Action ID="MoveTo">
            <input_port name="goal"/>
        </Action>
    </TreeNodesModel>
</root>