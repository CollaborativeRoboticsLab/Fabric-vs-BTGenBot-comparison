<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <FindPoseAction 
                 name="FindPose" 
                 goal_pose_not_updated_topic="/iken_pose" 
                 goal_pose_updated_topic="/iken_updated_pose" 
                 CP_topic="/cp_pose" 
                 EP_topic="/ep_pose" 
            />
            <MoveToAction 
                 name="MoveTo" 
                 goal_pose="{CP_pose}" 
                 />
            <VisitLocationAction 
                 name="VisitLocation" 
                 location="{EP_pose}" 
                 />
        </Sequence>
    </BehaviorTree>
</root>