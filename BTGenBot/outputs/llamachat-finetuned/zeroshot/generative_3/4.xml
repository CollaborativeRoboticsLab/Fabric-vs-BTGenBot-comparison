<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
           ; Visit Stations in sequence
            <VisitStations>
                <Sequence>
                    <SubTree ID="VisitStationA" />
                    <SubTree ID="VisitStationE" />
                    <SubTree ID="VisitStationC" />
                    <SubTree ID="VisitStationD" />
                </Sequence>
            </VisitStations>
            <!-- If StationE cannot be reached, move to StationB -->
            <Sequence>
                <SubTree ID="VisitStationE" status_check="NotReached" />
                <SubTree ID="MoveToStationB" />
            </Sequence>
        </Sequence>
    </BehaviorTree>
</root>