<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
           ; Visit Stations in sequence
            <ForceSuccess>
                <Sequence>
                    <Action ID="MoveTo" goal="StationA" />
                    <Action ID="MoveTo" goal="StationE" /> (else)
                    <Action ID="MoveTo" goal="StationF" />
                    <Action ID="MoveTo" goal="StationD" />
                </Sequence>
            </ForceSuccess>
            ; If StationE can't be reached, go to StationB
            <Fallback>
                <Action ID="MoveTo" goal="StationE" />
                <Action ID="MoveTo" goal="StationB" />
            </Fallback>
            ; If StationF can't be reached, go to StationC
            <Fallback>
                <Action ID="MoveTo" goal="StationF" />
                <Action ID="MoveTo" goal="StationC" />
            </Fallback>
        </Sequence>
    </BehaviorTree>
</root>