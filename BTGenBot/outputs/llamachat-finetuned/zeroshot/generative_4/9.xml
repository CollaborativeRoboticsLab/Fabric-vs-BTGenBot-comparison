<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <SubTree ID="StationEReached" />
            <SubTree ID="StationFReached" />
            <SubTree ID="StationDReached" />
            <SubTree ID="StationBReached" />
            <SubTree ID="StationCReched" />
        </Sequence>
    </BehaviorTree>
   <BehaviorTree ID="StationEReached">
       <Fallback>
           <Action ID="MoveTo" goal="StationE" />
           <Action ID="MoveTo" goal="StationB" />
       </Fallback>
   </BehaviorTree>
   <BehaviorTree ID="StationFReached">
       <Fallback>
           <Action ID="MoveTo" goal="StationF" />
           <Action ID="MoveTo" goal="StationC" />
       </Fallback>
   </BehaviorTree>
   <BehaviorTree ID="StationDReached">
       <Fallback>
           <Action ID="MoveTo" goal="StationD" />
           <Action ID="MoveTo" goal="StationC" />
       </Fallback>
   </BehaviorTree>
   <BehaviorTree ID="StationCReched">
       <Fallback>
           <Action ID="MoveTo" goal="StationC" />
       </Fallback>
   </BehaviorTree>
   <TreeNodesModel>
       <Action ID="MoveTo">
           <input_port name="goal"/>
       </Action>
   </TreeNodesModel>
</root>