<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in order -->
            <Fallback>
                <Sequence>
                    <GetPoseFrom pose_a="StationA" pose_b="StationB" pose_c="robot" filter_duration="2s" />
                </Sequence>
                <Sequence>
                    <GetPoseFrom pose_a="StationE" pose_b="StationB" pose_c="robot" filter_duration="2s" />
                </Sequence>
                <Sequence>
                    <GetPoseFrom pose_a="StationF" pose_b="StationB" pose_c="robot" filter_duration="2s" />
                </Sequence>
                <Sequence>
                    <GetPoseFrom pose_a="StationD" pose_b="StationB" pose_c="robot" filter_duration="2s" />
                </Sequence>
            </Fallback>
            <Sequence>
                <GetPoseFrom pose_a="StationB" pose_b="robot" pose_c="GPS" filter_duration="2s" />
            </Sequence>
            <Sequence>
                <MoveTo goal="{pose_c}" action="MoveTo" />
            </Sequence>
        </Sequence>
    </BehaviorTree>
</root>