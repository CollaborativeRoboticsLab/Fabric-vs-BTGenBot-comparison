<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in sequence -->
            <Fallback>
                <Sequence>
                    <GetPoseFromKeyStore name="station_a" location="{station_a}" />
                    <MoveToPath location="{station_a}" distance="5" path="{path_a}" />
                </Sequence>
                <Sequence>
                    <GetPoseFromKeyStore name="station_e" location="{station_e}" />
                    <MoveToPath location="{station_e}" distance="5" path="{path_e}" />
                </Sequence>
                <Sequence>
                    <GetPoseFromKeyStore name="station_f" location="{station_f}" />
                    <MoveToPath location="{station_f}" distance="5" path="{path_f}" />
                </Sequence>
                <Sequence>
                    <GetPoseFromKeyStore name="station_d" location="{station_d}" />
                    <MoveToPath location="{station_d}" distance="5" path="{path_d}" />
                </Sequence>
            </Fallback>
            <Fallback>
                <Sequence>
                    <GetPoseFromKeyStore name="station_b" location="{station_b}" />
                    <MoveToPath location="{station_b}" distance="5" path="{path_b}" />
                </Sequence>
            </Fallback>
        </Sequence>
    </BehaviorTree>
 </root>