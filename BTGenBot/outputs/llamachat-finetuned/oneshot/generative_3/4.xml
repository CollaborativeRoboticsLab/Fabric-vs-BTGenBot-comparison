<root main_tree_to_execute = "MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <MoveTo location="StationA"/>
            <MoveTo location="StationE"/>
            <MoveTo location="StationC"/>
            <MoveTo location="StationD"/>
            <IfAction potential_actions="MoveTo" is_action_able="false">
                StationE cannot be reached; therefore, move to StationB.
            </IfAction>
            <MoveTo location="StationB"/>
        </Sequence>
    </BehaviorTree>
</root>